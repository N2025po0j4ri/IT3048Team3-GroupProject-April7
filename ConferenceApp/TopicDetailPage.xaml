<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConferenceApp.TopicDetailPage"
             Title="TopicDetailPage">
    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20">

        <Image Grid.Row="0"  x:Name="TopicImage" HeightRequest="300"/>
        <Label Grid.Row="1" x:Name="LblTopicName"
        FontSize="Title"/>
        <Label Grid.Row="2" x:Name="LblTopicDesc"
        FontSize="Subtitle"/>
        <Grid Grid.Row="3" Padding="5" 
        VerticalOptions="Start"
        HorizontalOptions="Start">

                <Button Text="Back"
                  Clicked="backButton_Clicked"
                  VerticalOptions="Start"
                  HorizontalOptions="Start"/>

        </Grid>

    </Grid>
    
</ContentPage>
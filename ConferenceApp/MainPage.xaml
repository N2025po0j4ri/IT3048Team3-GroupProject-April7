<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConferenceApp.MainPage"
             Title="Conference Companion">

    <ScrollView>
        <Grid RowDefinitions="Auto,Auto,Auto,*">

            <Label Grid.Row="0"
                   Text="Conference Companion"
                   Style="{StaticResource Headline}"
                   Margin="0,20,0,10" />

            <Frame Grid.Row="1" Padding="10" Margin="20">
                <Button x:Name="Conf" Text="Companion Admin" Clicked="adminButton_Clicked"/>
            </Frame>

            <Frame Grid.Row="2"  Padding="10" Margin="20">
                <Button x:Name="startButton" Text="Getting Started" Clicked="startButton_Clicked" />
            </Frame>

        </Grid>
    </ScrollView>


</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConferenceApp.TopicsPage"
             Title="Sessions">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" >
        <Grid Grid.Row="0"
              ColumnDefinitions="*" >
            <Frame Padding="10" Grid.Column="0">
                <Label 
                Text=""
                x:Name="MessageLabel"
                FontAttributes="Bold"
                VerticalOptions="Center" 
                HorizontalOptions="End" />   
            </Frame>
        </Grid>
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*"
              ColumnSpacing="30"
              Margin="20" >

            <Frame Padding="10" Grid.Column="0">
                <Button x:Name="Home" Text="Sign Out" Clicked="SignOutButton_Clicked"/>
            </Frame>
            <Frame Padding="10" Grid.Column="1">
                <Button x:Name="favorite" Text="Favorites" Clicked="searchButton_Clicked"/>
            </Frame>
            
        </Grid>
        <SearchBar Grid.Row="2" x:Name="SessionSearch"
                   Placeholder="Search sessions..."
                   TextChanged="SessionSearch_TextChanged" />
        <Frame Grid.Row="3" BackgroundColor="LightBlue" Padding="10">
            <Label Text="Topics List" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

        </Frame>
        
        <CollectionView Grid.Row="4" 
        x:Name="LvTopics" 
        IsGrouped="True" 
        SelectionMode="Single" 
        SelectionChanged="LvTopic_SelectionChangedd"
        >

            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"/>
            </CollectionView.ItemsLayout>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Label FontSize="20" FontAttributes="Bold" TextColor="AntiqueWhite" BackgroundColor="Gray" Text="{Binding GroupName}"/>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Margin="20" Padding="10" >
                        <Image HeightRequest="60" WidthRequest="60" Source="{Binding ImageName}"/>
                        <Label FontSize="Medium" Text="{Binding TopicName}" HorizontalOptions="Center"/>
                        <Button Text="{Binding FavoriteIcon}"
                                FontSize="20"
                                BackgroundColor="Transparent"
                                TextColor="Gold"
                                CommandParameter="{Binding .}"
                                Clicked="FavoriteButton_Clicked"
                                HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
    
</ContentPage>
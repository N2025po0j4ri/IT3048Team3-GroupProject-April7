<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConferenceApp.TopicDetailPage"
             Title="Session Details">
    <ScrollView>
        <Grid Padding="20"
              RowSpacing="16"
              RowDefinitions="Auto,Auto">
            <Frame Grid.Row="0">
                <VerticalStackLayout Spacing="14">
                    <Image x:Name="TopicImage"
                           HeightRequest="240"
                           Aspect="AspectFill" />
                    <Label x:Name="LblTopicName"
                           FontSize="28"
                           FontAttributes="Bold" />
                    <Label x:Name="LblSpeakers"
                           FontSize="16"
                           TextColor="DimGray" />
                    <Label x:Name="LblTopicDesc"
                           FontSize="15"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Frame>

            <Button Grid.Row="1"
                    Text="Back"
                    WidthRequest="120"
                    HorizontalOptions="Start"
                    Clicked="backButton_Clicked" />
        </Grid>
    </ScrollView>
</ContentPage>

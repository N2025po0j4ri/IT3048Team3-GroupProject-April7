<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ConferenceApp.SearchPage"
             Title="Favorites">

    <Grid Padding="20"
          RowSpacing="16"
          RowDefinitions="Auto,Auto,*">
        <VerticalStackLayout Grid.Row="0"
                             Spacing="6">
            <Label Text="Favorite Sessions"
                   FontSize="28"
                   FontAttributes="Bold" />
            <Label Text="Search and review your saved sessions."
                   TextColor="DimGray" />
        </VerticalStackLayout>

        <SearchBar Grid.Row="1"
                   x:Name="SearchInput"
                   Placeholder="Search favorites..."
                   TextChanged="SearchInput_TextChanged" />

        <Grid Grid.Row="2"
              RowDefinitions="*,Auto"
              RowSpacing="16">
            <CollectionView Grid.Row="0"
                            x:Name="LvTopics">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical"
                                       ItemSpacing="14"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0">
                            <Grid ColumnDefinitions="72,*"
                                  ColumnSpacing="14">
                                <Image Grid.Column="0"
                                       HeightRequest="72"
                                       WidthRequest="72"
                                       Source="{Binding ImageName}"
                                       Aspect="AspectFill"
                                       VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1"
                                     Spacing="6"
                                     VerticalOptions="Center">
                                    <Label FontSize="18"
                                           FontAttributes="Bold"
                                           Text="{Binding TopicName}" />
                                    <Label Text="{Binding Speakers}"
                                           TextColor="DimGray"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding Day}"
                                           FontSize="13"
                                           TextColor="Gray"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Grid.Row="1"
                    Text="Back"
                    WidthRequest="120"
                    HorizontalOptions="Start"
                    Clicked="backButton_Clicked" />
        </Grid>
    </Grid>

</ContentPage>
